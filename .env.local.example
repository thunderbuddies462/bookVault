# Supabase — required for auth features (/auth/login, /auth/sign-in, /checkout protection)
# Get these from: https://supabase.com → Project Settings → API
#
# Without these, the app runs in demo mode:
#   - Browse, book detail, cart, reader, library, curated lists all work
#   - Auth pages render but Supabase calls are skipped
#   - /checkout redirects to /auth/login (middleware no-ops gracefully)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
