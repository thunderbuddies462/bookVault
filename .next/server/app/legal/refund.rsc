9:["$","$1","c",{"children":[["$","div",null,{"className":"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-24","children":[["$","p",null,{"className":"text-xs font-medium uppercase tracking-widest text-accent mb-4","children":"Legal"}],["$","h1",null,{"className":"font-display text-5xl font-semibold text-primary mb-3","children":"Refund Policy"}],["$","p",null,{"className":"text-sm text-secondary mb-12","children":"Last updated: 21 June 2026"}],["$","div",null,{"className":"space-y-10","children":[["$","section",null,{"children":[["$","h2",null,{"className":"font-display text-2xl font-semibold text-primary mb-4","children":"1. General Policy"}],["$","div",null,{"className":"space-y-3 text-sm text-secondary leading-relaxed [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-1.5 [&_strong]:font-medium","children":[["$","p",null,{"children":"Because bookVault sells digital content, all sales are generally final. Once you have downloaded or accessed digital content, we are unable to offer a refund under standard circumstances. This policy is consistent with digital goods regulations in most jurisdictions and mirrors industry practice among ebook platforms."}],["$","p",null,{"children":"However, we believe in fair treatment and will evaluate all refund requests on a case-by-case basis. Exceptions are detailed in the sections below."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"font-display text-2xl font-semibold text-primary mb-4","children":"2. Purchased Ebooks (Buy)"}],["$","div",null,{"className":"space-y-3 text-sm text-secondary leading-relaxed [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-1.5 [&_strong]:font-medium","children":[["$","p",null,{"children":"A refund may be issued for a purchased ebook if:"}],["$","ul",null,{"children":[["$","li",null,{"children":["You request a refund within ",["$","strong",null,{"className":"text-primary","children":"72 hours"}]," of purchase, and"]}],["$","li",null,{"children":"The content has not been downloaded or opened (as determined by our access logs)."}]]}],["$","p",null,{"children":"After 72 hours or after the content has been accessed, purchases are non-refundable. Refunds will not be granted because you changed your mind, found the book elsewhere at a lower price, or no longer wish to read it."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"font-display text-2xl font-semibold text-primary mb-4","children":"3. Rented Ebooks (Rent 7 or Rent 30 Days)"}],["$","div",null,{"className":"space-y-3 text-sm text-secondary leading-relaxed [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-1.5 [&_strong]:font-medium","children":[["$","p",null,{"children":"Rental fees are non-refundable once the rental period has begun. The rental period begins immediately upon payment. A refund may be issued only if:"}],["$","ul",null,{"children":[["$","li",null,{"children":["You have not accessed the content within ",["$","strong",null,{"className":"text-primary","children":"24 hours"}]," of the rental start time, and"]}],["$","li",null,{"children":"You contact support within those 24 hours requesting cancellation."}]]}],["$","p",null,{"children":"After 24 hours of rental access or after the content has been opened, no refund will be issued regardless of how much of the rental period remains."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"font-display text-2xl font-semibold text-primary mb-4","children":"4. Technical Issues"}],["$","div",null,{"className":"space-y-3 text-sm text-secondary leading-relaxed [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-1.5 [&_strong]:font-medium","children":[["$","p",null,{"children":"If you experience a genuine technical problem that prevents you from accessing content you paid for — such as a platform error, corrupted file delivery, or access failure not attributable to your device or internet connection — you are entitled to a full refund or replacement, regardless of the above time limits."}],"$Ld","$Le"]}]]}],"$Lf","$L10","$